# NextAuth Configuration
# openssl rand -base64 32
NEXTAUTH_SECRET=    # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Emails autorizados (lista separada por comas)
ALLOWED_EMAILS=    # owner@gmail.com,user@gmail.com

# Supabase (Supabase Dashboard → Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Solo desarrollo: omite Google OAuth (no usar en producción)
# BYPASS_AUTH=true

# Solo tests E2E/CI: usa cliente Supabase en memoria (no conecta a BD real)
# SUPABASE_MOCK=true
